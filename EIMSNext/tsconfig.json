{
  "compilerOptions": {
    "jsx": "preserve",
    "strict": true,
    "target": "es2017",
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom"
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  }
}
